# fix VIMINIT conflict with neovim
alias vim='VIMINIT="source ~/.config/vim/vimrc" vim'

# ls
alias ls='ls --color=auto'
alias la='ls -A'

# cd
alias d='dirs -v'
for index ({1..9}) alias "$index"="cd +${index} > /dev/null"; unset index

# python
alias python='python3'
alias py='python'
alias pip='pip3'

# ai stack
alias pi-sandbox-run='docker run --rm -it -v "$PWD:/workspace" -v ~/.pi/agent:/root/.pi/agent --add-host=host.docker.internal:host-gateway pi-sandbox'
alias pi='pi-sandbox-run'
